{
  "ConnectionStrings": {
    "Default": "Data Source=/data/notes.db"
  },
  "Jwt": {
    "Key": "${JWT_SECRET}",
    "Issuer": "NotesApp",
    "Audience": "NotesAppUsers"
  },
  "Redis": {
    "Connection": "redis:6379"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
